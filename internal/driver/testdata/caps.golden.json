{
  "engine": "iris",
  "contract": "1.0",
  "transports": [
    "local",
    "docker",
    "remote"
  ],
  "axes": {
    "meta": [
      "caps",
      "version",
      "info",
      "schema"
    ],
    "sync": [
      "list",
      "pull",
      "status",
      "verify",
      "push",
      "deploy"
    ]
  },
  "features": {
    "ephemeralPrefix": true,
    "prune": true,
    "remote": true,
    "snapshot": false
  }
}
