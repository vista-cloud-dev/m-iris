{
  "engine": "iris",
  "contract": "1.0",
  "transports": [
    "local",
    "docker",
    "remote"
  ],
  "axes": {
    "lifecycle": [
      "up",
      "down",
      "restart",
      "status",
      "wait",
      "provision",
      "destroy"
    ],
    "meta": [
      "caps",
      "version",
      "info",
      "schema",
      "doctor"
    ],
    "sync": [
      "list",
      "pull",
      "status",
      "verify",
      "push",
      "deploy"
    ]
  },
  "features": {
    "ephemeralPrefix": true,
    "prune": true,
    "remote": true,
    "snapshot": false
  }
}
